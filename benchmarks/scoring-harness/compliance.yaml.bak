# compliance.yaml — Regulatory Compliance Rules per Test Case
# Part of the ASA Biopharm AI/ML WG Agentic AI Benchmark
# Reference: benchmarks/regulatory-compliance.md

# ─────────────────────────────────────────────────────
# TC-001: Kaplan-Meier Median PFS Estimation
# ─────────────────────────────────────────────────────
TC-001:
  description: "KM Median PFS Estimation — single arm, ITT population"
  adam_mapping:
    required_variables: [AVAL, CNSR, TRT01PN, ITTFL, PARAMCD]
    population_flag: ITTFL
    population_value: Y
    treatment_variable: TRT01PN
    event_censor: [CNSR]
    time_variable: [AVAL]
  tcg_rules:
    - TCG-01: { population_filter: [ITTFL] }
    - TCG-02: { treatment_variable: [TRT01PN] }
    - TCG-03: { event_censor: [CNSR] }
    - TCG-04: { time_variable: [AVAL] }
    - TCG-05: {}
    - TCG-06: {}
    - TCG-08: {}
  csr_formatting:
    - CSR-01: {}
    - CSR-03: {}
    - CSR-05: {}
    - CSR-06: {}
  arm_required: false
  p21_rules: [P21-002, P21-003, P21-004, P21-005, P21-006]

# ─────────────────────────────────────────────────────
# TC-002: Baseline Demographics Table (Safety Population)
# ─────────────────────────────────────────────────────
TC-002:
  description: "Baseline Demographics Table — safety population, descriptive stats"
  adam_mapping:
    required_variables: [AGE, SEX, RACE, REGION1, ECOG, TRT01PN, SAFFL]
    population_flag: SAFFL
    population_value: Y
    treatment_variable: TRT01PN
  tcg_rules:
    - TCG-01: { population_filter: [SAFFL] }
    - TCG-02: { treatment_variable: [TRT01PN] }
    - TCG-05: {}
    - TCG-06: {}
  csr_formatting:
    - CSR-01: {}
    - CSR-02: {}
    - CSR-03: {}
  arm_required: false
  p21_rules: [P21-002, P21-004, P21-006]

# ─────────────────────────────────────────────────────
# TC-003: Stratified Log-Rank Test
# ─────────────────────────────────────────────────────
TC-003:
  description: "Stratified Log-Rank Test — ITT population, 2 stratification factors"
  adam_mapping:
    required_variables: [AVAL, CNSR, TRT01PN, SEX, ECOG, ITTFL, PARAMCD]
    population_flag: ITTFL
    population_value: Y
    treatment_variable: TRT01PN
    event_censor: [CNSR]
    time_variable: [AVAL]
    strata_variables: [SEX, ECOG]
  tcg_rules:
    - TCG-01: { population_filter: [ITTFL] }
    - TCG-02: { treatment_variable: [TRT01PN] }
    - TCG-03: { event_censor: [CNSR] }
    - TCG-04: { time_variable: [AVAL] }
    - TCG-05: {}
    - TCG-06: {}
    - TCG-09: {}
  csr_formatting:
    - CSR-01: {}
    - CSR-03: {}
    - CSR-04: {}
    - CSR-05: {}
  arm_required: false
  p21_rules: [P21-002, P21-003, P21-004, P21-005, P21-006]

# ─────────────────────────────────────────────────────
# TC-004: SAP Section for Primary Efficacy Analysis
# ─────────────────────────────────────────────────────
TC-004:
  description: "SAP section — Phase 3 oncology, stratified log-rank, OBF"
  adam_mapping:
    required_variables: [ITTFL, TRT01PN]
    population_flag: ITTFL
    population_value: Y
    treatment_variable: TRT01PN
  tcg_rules:
    - TCG-01: { population_filter: [ITTFL] }
    - TCG-02: { treatment_variable: [TRT01PN] }
    - TCG-05: {}
    - TCG-07: {}
    - TCG-09: {}
  csr_formatting:
    - CSR-04: {}
    - CSR-05: {}
    - CSR-07: {}
  arm_required: true
  p21_rules: []

# ─────────────────────────────────────────────────────
# TC-005: TFL Package QC Review
# ─────────────────────────────────────────────────────
TC-005:
  description: "TFL QC Review — SAP consistency, 3 seeded errors"
  adam_mapping:
    required_variables: [ITTFL, SAFFL, PPROTFL, TRT01PN]
    population_flag: null
    population_value: null
    treatment_variable: TRT01PN
  tcg_rules:
    - TCG-01: {}
    - TCG-02: { treatment_variable: [TRT01PN] }
    - TCG-05: {}
    - TCG-06: {}
  csr_formatting:
    - CSR-01: {}
    - CSR-02: {}
  arm_required: false
  p21_rules: [P21-004]

# ─────────────────────────────────────────────────────
# TC-006: Sample Size Re-Estimation at Interim
# ─────────────────────────────────────────────────────
TC-006:
  description: "Sample size re-estimation — blinded interim, conditional power"
  adam_mapping:
    required_variables: [AVAL, CNSR, ITTFL]
    population_flag: ITTFL
    population_value: Y
  tcg_rules:
    - TCG-05: {}
    - TCG-07: {}
  csr_formatting: []
  arm_required: false
  p21_rules: [P21-005]

# ─────────────────────────────────────────────────────
# TC-007: Regulatory Response — ITT vs PP Discrepancy
# ─────────────────────────────────────────────────────
TC-007:
  description: "Regulatory response — ITT/PP discrepancy analysis"
  adam_mapping:
    required_variables: [AVAL, CNSR, TRT01PN, ITTFL, PPROTFL]
    population_flag: null  # Both ITT and PP are relevant
    population_value: null
    treatment_variable: TRT01PN
    event_censor: [CNSR]
  tcg_rules:
    - TCG-01: {}
    - TCG-02: { treatment_variable: [TRT01PN] }
    - TCG-05: {}
    - TCG-07: {}
    - TCG-08: {}
    - TCG-09: {}
  csr_formatting:
    - CSR-02: {}
    - CSR-04: {}
    - CSR-05: {}
    - CSR-07: {}
  arm_required: false
  p21_rules: [P21-002, P21-004, P21-005]

# ─────────────────────────────────────────────────────
# TC-008: Dose-Finding Study Design
# ─────────────────────────────────────────────────────
TC-008:
  description: "Phase 2 dose-finding design — Bayesian, operating characteristics"
  adam_mapping:
    required_variables: []
    population_flag: null
    population_value: null
  tcg_rules:
    - TCG-05: {}
  csr_formatting:
    - CSR-07: {}
  arm_required: false
  p21_rules: []

# ─────────────────────────────────────────────────────
# TC-009: Safety Signal Evaluation / DMC Report
# ─────────────────────────────────────────────────────
TC-009:
  description: "Safety signal evaluation — DMC report, exposure-adjusted rates"
  adam_mapping:
    required_variables: [SAFFL, TRT01PN, AESEV, AESER, AESDTH, AEDECOD, AEBODSYS]
    population_flag: SAFFL
    population_value: Y
    treatment_variable: TRT01PN
  tcg_rules:
    - TCG-01: { population_filter: [SAFFL] }
    - TCG-02: { treatment_variable: [TRT01PN] }
    - TCG-05: {}
    - TCG-06: {}
    - TCG-07: {}
  csr_formatting:
    - CSR-01: {}
    - CSR-02: {}
    - CSR-03: {}
    - CSR-07: {}
  arm_required: false
  p21_rules: [P21-002, P21-004, P21-006]

# ─────────────────────────────────────────────────────
# TC-010: CSR Section — Statistical Methods and Results
# ─────────────────────────────────────────────────────
TC-010:
  description: "CSR Section 9 + 11 — ICH E3-compliant statistical reporting"
  adam_mapping:
    required_variables: [ITTFL, SAFFL, PPROTFL, TRT01PN, AVAL, CNSR, AEDECOD]
    population_flag: null  # Multiple populations across sections
    population_value: null
    treatment_variable: TRT01PN
  tcg_rules:
    - TCG-01: {}
    - TCG-02: { treatment_variable: [TRT01PN] }
    - TCG-05: {}
    - TCG-06: {}
    - TCG-07: {}
    - TCG-08: {}
    - TCG-09: {}
  csr_formatting:
    - CSR-01: {}
    - CSR-02: {}
    - CSR-03: {}
    - CSR-04: {}
    - CSR-05: {}
    - CSR-06: {}
    - CSR-07: {}
  arm_required: true
  p21_rules: [P21-002, P21-003, P21-004, P21-005, P21-006]

# ─────────────────────────────────────────────────────
# Global Configuration
# ─────────────────────────────────────────────────────
global:
  # Scoring: how compliance score is folded into total TC score
  compliance_weight:
    level_1: 0.30    # 30% compliance for auto-scorable TCs
    level_2: 0.25    # 25% compliance for partially auto TCs
    level_3: 0.20    # 20% compliance for expert-review TCs
  # Penalty: score multiplier when critical compliance failures are found
  critical_failure_multiplier: 0.0  # Score = 0 for that component
