{
  "method": "BOIN",
  "method_full": "Bayesian Optimal Interval",
  "target_dlt_rate": 0.3,
  "n_doses": 5,
  "dose_levels": [10, 20, 40, 80, 120],
  "true_dlt_rates": [0.05, 0.12, 0.25, 0.35, 0.45],
  "cohort_size": 3,
  "max_n": 30,
  "starting_dose": 1,
  "escalation_boundary": 0.2308,
  "deescalation_boundary": 0.4286,
  "expansion_cohort_size": 6,
  "stopping_rules": [
    {
      "id": "SR-1",
      "description": "Stop if dose 1 observed DLT rate exceeds de-escalation boundary (all doses too toxic)"
    },
    {
      "id": "SR-2",
      "description": "Stop if total sample size reaches max_n (30)"
    },
    {
      "id": "SR-3",
      "description": "Select MTD/RP2D as dose with observed DLT rate closest to target"
    }
  ],
  "seed": 42,
  "n_sim": 2000
}
