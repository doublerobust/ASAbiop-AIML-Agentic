{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "TC-020: ORR by Subgroup Output Schema",
  "description": "Structured output from ORR by subgroup benchmark test case",
  "type": "object",
  "required": [
    "test_case_id", "variant_id", "language", "package",
    "overall", "subgroups", "interaction_pvalues", "seed"
  ],
  "properties": {
    "test_case_id": {
      "type": "string",
      "const": "TC-020",
      "description": "Test case identifier"
    },
    "variant_id": {
      "type": ["string", "null"],
      "description": "Variant identifier based on seed"
    },
    "language": {
      "type": "string",
      "enum": ["R", "SAS", "Python"],
      "description": "Implementation language"
    },
    "package": {
      "type": "string",
      "description": "Primary package used"
    },
    "package_version": {
      "type": "string",
      "description": "Package version string"
    },
    "overall": {
      "type": "object",
      "required": ["orr_experimental", "orr_control", "n_experimental", "n_control",
                    "responders_experimental", "responders_control", "orr_difference"],
      "properties": {
        "orr_experimental": {"type": "number", "minimum": 0, "maximum": 100},
        "orr_control": {"type": "number", "minimum": 0, "maximum": 100},
        "n_experimental": {"type": "integer", "minimum": 0},
        "n_control": {"type": "integer", "minimum": 0},
        "responders_experimental": {"type": "integer", "minimum": 0},
        "responders_control": {"type": "integer", "minimum": 0},
        "ci_lower_experimental": {"type": "number"},
        "ci_upper_experimental": {"type": "number"},
        "ci_lower_control": {"type": "number"},
        "ci_upper_control": {"type": "number"},
        "orr_difference": {"type": "number"}
      }
    },
    "subgroups": {
      "type": "array",
      "description": "Subgroup-level ORR results",
      "items": {
        "type": "object",
        "required": ["subgroup", "level", "orr_experimental", "orr_control",
                      "n_experimental", "n_control", "orr_difference"],
        "properties": {
          "subgroup": {"type": "string"},
          "level": {"type": "string"},
          "orr_experimental": {"type": "number", "minimum": 0, "maximum": 100},
          "orr_control": {"type": "number", "minimum": 0, "maximum": 100},
          "n_experimental": {"type": "integer", "minimum": 0},
          "n_control": {"type": "integer", "minimum": 0},
          "responders_experimental": {"type": "integer", "minimum": 0},
          "responders_control": {"type": "integer", "minimum": 0},
          "ci_lower_experimental": {"type": "number"},
          "ci_upper_experimental": {"type": "number"},
          "ci_lower_control": {"type": "number"},
          "ci_upper_control": {"type": "number"},
          "orr_difference": {"type": "number"},
          "diff_ci_lower": {"type": "number"},
          "diff_ci_upper": {"type": "number"}
        }
      }
    },
    "interaction_pvalues": {
      "type": "array",
      "description": "CMH interaction test results per subgroup",
      "items": {
        "type": "object",
        "required": ["subgroup", "cmh_p_value"],
        "properties": {
          "subgroup": {"type": "string"},
          "cmh_p_value": {"type": ["number", "null"]},
          "cmh_common_or": {"type": ["number", "null"]}
        }
      }
    },
    "seed": {"type": ["integer", "null"]}
  }
}
