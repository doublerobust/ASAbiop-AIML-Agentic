{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tc-012-output-schema",
  "title": "TC-012: Forest Plot Subgroup HRs Output",
  "description": "Schema for forest plot subgroup hazard ratio analysis",
  "type": "object",
  "required": [
    "test_case_id",
    "title",
    "parameters",
    "overall",
    "subgroups",
    "metadata"
  ],
  "properties": {
    "test_case_id": {
      "type": "string",
      "const": "TC-012"
    },
    "title": {
      "type": "string"
    },
    "parameters": {
      "type": "object",
      "required": [
        "seed",
        "n_subjects"
      ],
      "properties": {
        "seed": {
          "type": "integer"
        },
        "n_subjects": {
          "type": "integer",
          "minimum": 50
        }
      }
    },
    "overall": {
      "$ref": "#/$defs/hr_result"
    },
    "subgroups": {
      "type": "array",
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/hr_result"
          },
          {
            "type": "object",
            "required": [
              "subgroup",
              "variable",
              "value"
            ],
            "properties": {
              "subgroup": {
                "type": "string"
              },
              "variable": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          }
        ]
      }
    },
    "interaction_pvalues": {
      "type": "object",
      "additionalProperties": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    },
    "metadata": {
      "type": "object",
      "required": [
        "language",
        "method"
      ],
      "properties": {
        "language": {
          "type": "string"
        },
        "method": {
          "type": "string"
        },
        "ci_method": {
          "type": "string"
        },
        "packages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "hr_result": {
      "type": "object",
      "required": [
        "hr",
        "ci_lower",
        "ci_upper",
        "n_experimental",
        "n_control"
      ],
      "properties": {
        "hr": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "ci_lower": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "ci_upper": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "n_experimental": {
          "type": "integer",
          "minimum": 1
        },
        "n_control": {
          "type": "integer",
          "minimum": 1
        },
        "events_experimental": {
          "type": "integer",
          "minimum": 0
        },
        "events_control": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}